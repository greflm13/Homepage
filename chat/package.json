    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/platform-server": "^20.3.17",
    "@angular/pwa": "^0.803.21",
    "@angular/router": "^20.3.17",
    "@angular/ssr": "^20.3.18",
    "@ctrl/ngx-emoji-mart": "^9.3.0",
    "@types/core-js": "^2.5.2",
    "bootstrap": "^4.4.1",
    "classlist.js": "^1.1.20150312",
