{
  "name": "chat",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prerestart": "npm run build",
    "restart": "scp -r dist/* $HOST:/home/net/server",
    "start": "npm run build",
    "build": "ng build --configuration production --base-href=/chat/",
    "test": "ng build --watch --base-href=/chat/",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "serve:ssr:chat": "node dist/chat/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/pwa": "^0.803.21",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@ctrl/ngx-emoji-mart": "^9.3.0",
    "@types/core-js": "^2.5.2",
    "bootstrap": "^4.4.1",
    "classlist.js": "^1.1.20150312",
    "core-js": "^3.6.0",
    "express": "^5.1.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/language-service": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "browser-sync": "^3.0.0",
    "ts-loader": "^5.4.5",
    "ts-node": "^8.5.4",
    "typescript": "5.9.3"
  }
}