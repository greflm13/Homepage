{
  "name": "chat",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prerestart": "npm run build",
    "restart": "scp -r dist/* $HOST:/home/net/server",
    "start": "npm run build",
    "build": "ng build --configuration production --base-href=/chat/",
