{
  "name": "discord",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prerestart": "npm run build",
    "restart": "scp -r dist/* $HOST:/home/pi/server",
    "start": "npm run build",
    "build": "ng build --configuration production --build-optimizer --base-href=/discord/",
    "test": "ng build --watch --base-href=/discord/",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "core-js": "^2.5.4",
    "rxjs": "~6.6.7",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.18",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.17",
    "@angular/language-service": "^20.3.17",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "^2.0.6",
    "@types/node": "^12.11.1",
    "codelyzer": "^6.0.0",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "protractor": "~7.0.0",
    "ts-node": "^7.0.1",
    "tslint": "~6.1.0",
    "typescript": "5.8.3"
  }
