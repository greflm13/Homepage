{
  "name": "minesweeper",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prerestart": "npm run build",
    "restart": "scp -r dist/* $HOST:/home/pi/server",
    "start": "npm run build",
    "build": "ng build --configuration production --build-optimizer --base-href=/minesweeper/",
    "test": "ng build --watch --base-href=/minesweeper/",
    "lint": "ng lint",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^13.4.0",
    "@angular/common": "^13.4.0",
    "@angular/compiler": "^13.4.0",
    "@angular/core": "^13.4.0",
    "@angular/forms": "^13.4.0",
    "@angular/localize": "^13.4.0",
    "@angular/platform-browser": "^13.4.0",
    "@angular/platform-browser-dynamic": "^13.4.0",
    "@angular/router": "^13.4.0",
    "@ng-bootstrap/ng-bootstrap": "^11.0.1",
    "bootstrap": "^5.3.8",
    "rxjs": "^6.6.7",
    "tslib": "^2.0.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~13.3.11",
    "@angular/cli": "^13.3.11",
    "@angular/compiler-cli": "^13.4.0",
    "@angular/language-service": "^13.4.0",
    "@types/node": "^14.18.63",
    "karma": "~6.4.4",
    "ts-node": "^5.0.1",
    "typescript": "4.6.4"
  }
}
